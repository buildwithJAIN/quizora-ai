// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  apiKeyEnc String?
  createdAt DateTime @default(now())
  quizzes   Quiz[]
  results   Result[]
}

model Quiz {
  id          String   @id @default(uuid())
  topic       String
  difficulty  String?
  questions   Json
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])
  userId      String?
  results     Result[]
}

model Result {
  id            String   @id @default(uuid())
  score         Int
  totalQuestions Int
  accuracy      Float
  createdAt     DateTime @default(now())
  quiz          Quiz     @relation(fields: [quizId], references: [id])
  quizId        String
  user          User     @relation(fields: [userId], references: [id])
  userId        String
}